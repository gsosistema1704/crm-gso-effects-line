end $$;

do $$
declare
  policy_name text;
begin
  for policy_name in
    select pol.policyname
    from pg_policies pol
    where pol.schemaname = 'storage'
      and pol.tablename = 'objects'
      and pol.policyname like 'gso_crm_%'
